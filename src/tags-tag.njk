---
pagination:
  data: collections.validTagList
  size: 1
  alias: tag
  addAllPagesToCollections: true
layout: base.njk
permalink: /tags/{{ tag | slugify }}/
eleventyComputed:
  title: Posts tagged "{{ tag }}"
---

<!-- Terminal Hero -->
<section class="mb-16">
  <div class="terminal-window bg-terminal-surface/80 backdrop-blur-md border border-terminal-border rounded-xl overflow-hidden max-w-3xl mx-auto shadow-2xl relative group">
    <div class="absolute inset-0 bg-gradient-to-br from-terminal-green/5 to-terminal-cyan/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    <div class="terminal-chrome bg-terminal-darker/90 px-4 py-3 flex items-center justify-between border-b border-terminal-border">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500/80 hover:bg-red-400 transition-colors"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/80 hover:bg-yellow-400 transition-colors"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/80 hover:bg-green-400 transition-colors"></div>
      </div>
      <div class="text-xs text-terminal-dim font-mono flex items-center gap-2">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
        ~/knowledge/tags/{{ tag | slugify }}
      </div>
    </div>
    <div class="terminal-body p-6 md:p-10 font-mono text-center relative z-10">
      <h1 class="text-3xl md:text-5xl font-bold mb-4 text-terminal-light-surface font-mono flex justify-center items-center gap-3">
        <span class="text-terminal-green opacity-50">#</span>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-terminal-green to-terminal-cyan">{{ tag }}</span>
      </h1>
      <div class="flex items-center justify-center gap-2 text-terminal-dim mt-6">
        <span class="text-terminal-green">$</span>
        <span class="typing-animation">ls -l | grep "{{ tag }}"</span>
      </div>
    </div>
  </div>
</section>

{% set postslist = collections.posts | getByTag(tag) %}

<div class="max-w-3xl mx-auto mb-16 relative">
  <!-- Decorative timeline line -->
  <div class="absolute left-0 md:left-4 top-0 bottom-0 w-px bg-gradient-to-b from-terminal-green/50 via-terminal-border to-transparent hidden md:block"></div>

  {% if postslist.length === 0 %}
    <div class="text-center py-20 bg-terminal-surface/30 backdrop-blur-sm rounded-2xl border border-dashed border-terminal-border relative overflow-hidden group max-w-2xl mx-auto md:ml-12">
      <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(74,222,128,0.02)_50%,transparent_75%)] bg-[length:250%_250%,100%_100%] animate-[gradient_3s_linear_infinite] opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <div class="relative z-10">
        <p class="text-terminal-light-surface font-mono font-medium">No posts found with this tag</p>
      </div>
    </div>
  {% else %}
    <div class="space-y-6 md:pl-12">
      {% for post in postslist %}
      <article class="relative group" data-reveal style="transition-delay: {{ loop.index0 * 50 }}ms;">
        <!-- Timeline node -->
        <div class="absolute -left-12 top-8 w-3 h-3 rounded-full bg-terminal-dark border-2 border-terminal-green hidden md:block group-hover:bg-terminal-green group-hover:scale-150 transition-all duration-300 shadow-[0_0_10px_rgba(74,222,128,0.5)]"></div>
        
        <a href="{{ post.url }}" class="block">
          <!-- Animated gradient border background -->
          <div class="absolute -inset-0.5 bg-gradient-to-r from-terminal-green/50 to-terminal-cyan/50 rounded-2xl blur opacity-0 group-hover:opacity-30 transition duration-500"></div>
          
          <div class="relative bg-terminal-surface/60 backdrop-blur-sm border border-terminal-border rounded-xl p-6 group-hover:border-terminal-green/50 transition-all duration-300 transform group-hover:-translate-y-1 hover:shadow-xl hover:shadow-terminal-green/5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <h2 class="text-2xl font-bold text-terminal-light-surface mb-3 group-hover:text-terminal-green transition-colors">
                  {{ post.data.title }}
                </h2>
                
                {% if post.data.description %}
                <p class="text-terminal-dim mb-4 leading-relaxed line-clamp-2 group-hover:text-terminal-light-surface transition-colors">{{ post.data.description }}</p>
                {% endif %}
                
                <div class="flex flex-wrap items-center gap-3 text-sm">
                  <time datetime="{{ post.date | htmlDateString }}" class="text-terminal-dim flex items-center gap-1.5 font-mono bg-terminal-darker px-2.5 py-1 rounded-md border border-terminal-border/50">
                    <svg class="w-3.5 h-3.5 text-terminal-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    {{ post.date | readableDate }}
                  </time>
                  
                  {% if post.data.tags %}
                    <div class="flex gap-2 items-center flex-wrap ml-2 border-l border-terminal-border/50 pl-3">
                    {% for t in post.data.tags %}
                      {% if t != "posts" %}
                      <span class="text-xs font-mono px-2 py-0.5 rounded border {% if t == tag %}border-terminal-green text-terminal-darker bg-terminal-green font-bold{% else %}border-terminal-border/50 text-terminal-dim bg-terminal-darker group-hover:border-terminal-green/30{% endif %} transition-colors">#{{ t }}</span>
                      {% endif %}
                    {% endfor %}
                    </div>
                  {% endif %}
                </div>
              </div>
              
              <div class="flex-shrink-0 mt-2 w-8 h-8 rounded-full bg-terminal-darker border border-terminal-border flex items-center justify-center group-hover:border-terminal-green group-hover:bg-terminal-green/10 transition-all duration-300 group-hover:translate-x-1">
                <svg class="w-4 h-4 text-terminal-dim group-hover:text-terminal-green transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </div>
        </a>
      </article>
      {% endfor %}
    </div>
  {% endif %}
</div>

<!-- Navigation -->
<div class="mt-8 mb-16 flex flex-wrap justify-center gap-4">
  <a href="/tags/" class="group relative inline-flex items-center gap-2 px-6 py-3 bg-terminal-surface border border-terminal-border rounded-lg font-mono text-terminal-light-surface hover:text-terminal-green hover:border-terminal-green transition-all duration-300 active:scale-95 overflow-hidden">
    <div class="absolute inset-0 bg-terminal-green/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
    <svg class="w-4 h-4 relative z-10 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
    </svg>
    <span class="relative z-10">All Tags</span>
  </a>
  <a href="/" class="group relative inline-flex items-center gap-2 px-6 py-3 bg-terminal-green border border-terminal-green text-terminal-darker rounded-lg font-mono font-bold hover:bg-terminal-cyan hover:border-terminal-cyan transition-all duration-300 hover:shadow-[0_0_15px_rgba(74,222,128,0.4)] active:scale-95 overflow-hidden">
    <svg class="w-4 h-4 relative z-10 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
    </svg>
    <span class="relative z-10">cd ~/home</span>
  </a>
</div>
