<header class="sticky top-0 z-50 backdrop-blur-xl bg-terminal-light-bg/70 dark:bg-terminal-dark/70 border-b border-terminal-light-border dark:border-terminal-border transition-all duration-300 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)]">
  <!-- Subtle top gradient line -->
  <div class="absolute top-0 inset-x-0 h-[1px] bg-gradient-to-r from-transparent via-terminal-green/50 to-transparent"></div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16 relative">
      <a href="/" class="text-xl font-bold font-mono group flex items-center gap-1 transition-opacity">
        <span class="text-terminal-green group-hover:text-terminal-cyan transition-colors">$</span>
        <span class="text-terminal-darker dark:text-terminal-light-surface group-hover:text-terminal-green transition-colors">{{ site.title }}</span>
        <span class="inline-block w-2.5 h-5 bg-terminal-green opacity-0 group-hover:opacity-100 group-hover:animate-pulse ml-0.5 transition-opacity"></span>
      </a>
      
      <!-- Mobile hamburger button (visible below md) -->
      <button data-nav-toggle class="md:hidden p-2.5 rounded-lg bg-terminal-surface/50 border border-terminal-border text-terminal-dim hover:text-terminal-green hover:border-terminal-green/50 hover:bg-terminal-green/10 transition-all duration-300 active:scale-95" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      
      <div class="hidden md:flex items-center space-x-1">
        {% set navItems = [
          { name: 'Home', url: '/' },
          { name: 'Tags', url: '/tags/' },
          { name: 'About', url: '/about/' },
          { name: 'Photography', url: '/photography/' },
          { name: 'Projects', url: '/projects/' },
          { name: 'RSS', url: '/feed.xml' }
        ] %}
        
        {% for item in navItems %}
          {% set isActive = page.url == item.url %}
          <a href="{{ item.url }}" class="relative px-3 py-2 text-sm font-medium rounded-md transition-all duration-300 group {% if isActive %}text-terminal-green{% else %}text-terminal-dim hover:text-terminal-darker dark:hover:text-terminal-light-surface{% endif %}">
            <span class="relative z-10">{{ item.name }}</span>
            <span class="absolute inset-0 rounded-md bg-terminal-green/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 scale-95 group-hover:scale-100"></span>
            {% if isActive %}
              <span class="absolute bottom-1.5 left-3 right-3 h-[2px] bg-terminal-green rounded-full shadow-[0_0_8px_rgba(74,222,128,0.8)]"></span>
            {% else %}
              <span class="absolute bottom-1.5 left-1/2 right-1/2 h-[2px] bg-terminal-green rounded-full opacity-0 group-hover:opacity-100 group-hover:left-3 group-hover:right-3 transition-all duration-300"></span>
            {% endif %}
          </a>
        {% endfor %}
        
        <div class="pl-3 ml-2 border-l border-terminal-light-border dark:border-terminal-border">
          <!-- Dark Mode Toggle -->
          <button id="theme-toggle" class="relative p-2.5 rounded-full bg-terminal-surface dark:bg-terminal-darker border border-terminal-border hover:border-terminal-green/50 text-terminal-dim hover:text-terminal-green dark:hover:text-terminal-cyan transition-all duration-300 hover:shadow-[0_0_15px_rgba(74,222,128,0.15)] active:scale-95 overflow-hidden group" aria-label="Toggle dark mode">
            <div class="absolute inset-0 bg-terminal-green/0 group-hover:bg-terminal-green/10 transition-colors duration-300"></div>
            <!-- Sun icon -->
            <svg id="sun-icon" class="w-4 h-4 hidden dark:block relative z-10 transition-transform duration-500 group-hover:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <!-- Moon icon -->
            <svg id="moon-icon" class="w-4 h-4 block dark:hidden relative z-10 transition-transform duration-500 group-hover:-rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>
    
    <!-- Mobile menu panel (hidden by default) -->
    <div id="mobile-menu" data-nav-menu class="hidden md:hidden absolute left-0 right-0 top-16 border-t border-terminal-light-border dark:border-terminal-border bg-terminal-light-bg/95 dark:bg-terminal-dark/95 backdrop-blur-xl shadow-xl shadow-terminal-dark/10">
      <div class="px-4 py-4 space-y-1 max-w-4xl mx-auto">
        {% for item in navItems %}
          {% set isActive = page.url == item.url %}
          <a href="{{ item.url }}" class="flex items-center gap-3 px-3 py-3 rounded-lg text-base font-medium transition-colors {% if isActive %}text-terminal-green bg-terminal-green/5{% else %}text-terminal-dim hover:text-terminal-darker dark:hover:text-terminal-light-surface hover:bg-terminal-surface{% endif %}">
            <span class="text-terminal-green opacity-50">
              {% if loop.index == 1 %}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
              {% elif loop.index == 2 %}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
              {% elif loop.index == 3 %}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              {% elif loop.index == 4 %}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              {% elif loop.index == 5 %}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
              {% elif loop.index == 6 %}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"></path></svg>
              {% endif %}
            </span>
            {{ item.name }}
          </a>
        {% endfor %}
        <div class="pt-2 mt-2 border-t border-terminal-border">
          <!-- Dark mode toggle (duplicate for mobile) -->
          <button id="theme-toggle-mobile" class="w-full flex items-center justify-between px-3 py-3 rounded-lg text-terminal-dim hover:text-terminal-darker dark:hover:text-terminal-light-surface hover:bg-terminal-surface transition-colors" aria-label="Toggle dark mode">
            <span class="text-base font-medium">Dark Mode</span>
            <span class="p-2 rounded-full bg-terminal-surface/50 border border-terminal-border">
              <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
</header>