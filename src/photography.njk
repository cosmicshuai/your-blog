---
layout: base.njk
title: Photography
---

<div class="mb-12">
  <div class="font-mono text-xl md:text-2xl text-terminal-light-surface dark:text-terminal-light-surface mb-8 flex items-center gap-3">
    <span class="text-terminal-green select-none">$</span>
    <h1 class="m-0 text-inherit font-normal inline-block">ls ~/photos</h1>
  </div>

  {% if photos.length === 0 %}
    <div class="terminal-window bg-terminal-surface border border-terminal-border rounded-lg overflow-hidden max-w-2xl">
      <div class="terminal-chrome bg-terminal-darker px-4 py-3 flex items-center gap-2 border-b border-terminal-border">
        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
      </div>
      <div class="terminal-body p-6 font-mono text-terminal-dim">
        ls: ~/photos: No such file or directory
      </div>
    </div>
  {% else %}
    <div class="photo-gallery">
      {% for photo in photos %}
        <div class="photo-item mb-4 cursor-pointer relative group break-inside-avoid">
          {% galleryImage photo.src, photo.alt, "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw", "gallery-image w-full h-auto rounded border border-terminal-border transition-all duration-300 group-hover:border-terminal-green group-hover:opacity-90" %}
          {% if photo.caption %}
            <div class="hidden photo-caption" data-caption="{{ photo.caption }}"></div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<!-- Lightbox Container -->
<div id="lightbox" class="fixed inset-0 z-50 hidden opacity-0 transition-opacity duration-300 bg-terminal-dark/95 backdrop-blur-sm flex items-center justify-center" aria-modal="true" role="dialog" aria-label="Image gallery">
  <button id="lightbox-close" class="absolute top-4 right-4 z-50 text-terminal-dim hover:text-terminal-green transition-colors p-2 focus:outline-none focus:ring-2 focus:ring-terminal-green rounded" aria-label="Close lightbox">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  
  <button id="lightbox-prev" class="absolute left-4 z-50 text-terminal-dim hover:text-terminal-green transition-colors p-2 focus:outline-none focus:ring-2 focus:ring-terminal-green rounded" aria-label="Previous image">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  
  <div class="lightbox-content relative max-w-[90vw] max-h-[90vh] flex flex-col items-center justify-center">
    <img id="lightbox-image" src="" alt="" class="max-w-full max-h-[85vh] object-contain shadow-2xl rounded border border-terminal-border" />
    <div id="lightbox-caption" class="mt-4 font-mono text-terminal-green text-sm md:text-base hidden text-center"></div>
  </div>
  
  <button id="lightbox-next" class="absolute right-4 z-50 text-terminal-dim hover:text-terminal-green transition-colors p-2 focus:outline-none focus:ring-2 focus:ring-terminal-green rounded" aria-label="Next image">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>
