---
layout: base.njk
title: Photography
---

<div class="mb-20">
  <!-- Terminal Header -->
  <section class="mb-16">
    <div class="terminal-window bg-terminal-surface/80 backdrop-blur-md border border-terminal-border rounded-xl overflow-hidden max-w-3xl mx-auto shadow-2xl relative group">
      <div class="absolute inset-0 bg-gradient-to-br from-terminal-green/5 to-terminal-cyan/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="terminal-chrome bg-terminal-darker/90 px-4 py-3 flex items-center justify-between border-b border-terminal-border">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded-full bg-red-500/80 hover:bg-red-400 transition-colors"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/80 hover:bg-yellow-400 transition-colors"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/80 hover:bg-green-400 transition-colors"></div>
        </div>
        <div class="text-xs text-terminal-dim font-mono flex items-center gap-2">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          ~/media/photos
        </div>
      </div>
      <div class="terminal-body p-6 md:p-10 font-mono text-left relative z-10">
        <div class="flex items-center gap-2 text-lg md:text-xl text-terminal-light-surface">
          <span class="text-terminal-green select-none">$</span>
          <span class="text-terminal-light-surface typing-animation">ls -la *.jpg *.png</span>
        </div>
        <p class="mt-6 text-terminal-dim text-sm md:text-base leading-relaxed border-l-2 border-terminal-green/30 pl-4 py-1">
          Visual stories and moments captured through the lens. Total items: <span class="text-terminal-cyan">{{ photos.length | default(0) }}</span>.
        </p>
      </div>
    </div>
  </section>

  {% if photos.length === 0 %}
    <div class="text-center py-24 bg-terminal-surface/30 backdrop-blur-sm rounded-2xl border border-dashed border-terminal-border relative overflow-hidden group max-w-4xl mx-auto">
      <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(74,222,128,0.02)_50%,transparent_75%)] bg-[length:250%_250%,100%_100%] animate-[gradient_3s_linear_infinite] opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <div class="relative z-10">
        <div class="font-mono mb-4 text-xl">
          <span class="text-terminal-green">$</span>
          <span class="text-terminal-dim">find . -type f -name "*.jpg"</span>
        </div>
        <p class="text-terminal-light-surface mb-3 font-mono font-medium">No photos found in directory</p>
        <code class="bg-terminal-darker/80 px-4 py-2 rounded-lg text-sm text-terminal-green inline-block border border-terminal-border/50 shadow-inner shadow-black/20">src/_data/photos.json</code>
      </div>
    </div>
  {% else %}
    <div class="photo-gallery max-w-7xl mx-auto px-2">
      {% for photo in photos %}
        <div class="photo-item mb-6 cursor-pointer relative group break-inside-avoid rounded-xl overflow-hidden shadow-lg shadow-black/20" data-reveal style="transition-delay: {{ (loop.index0 % 3) * 100 }}ms;">
          <!-- Animated gradient border (visible on hover) -->
          <div class="absolute inset-0 rounded-xl border-2 border-transparent group-hover:border-terminal-green/80 z-20 transition-all duration-300 pointer-events-none"></div>
          
          <div class="relative overflow-hidden w-full h-full bg-terminal-surface rounded-xl">
            <!-- Image with scale effect -->
            {% galleryImage photo.src, photo.alt, "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw", "gallery-image w-full h-auto transform transition-transform duration-700 ease-out group-hover:scale-105" %}
            
            {% if photo.caption %}
              <div class="hidden photo-caption" data-caption="{{ photo.caption }}"></div>
              <!-- Gradient overlay and caption fade in -->
              <div class="absolute inset-0 bg-gradient-to-t from-terminal-darker/90 via-terminal-darker/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-start p-6">
                <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                  <p class="text-terminal-light-surface font-mono text-sm border-l-2 border-terminal-green pl-3 shadow-sm">
                    {{ photo.caption }}
                  </p>
                </div>
              </div>
            {% else %}
              <div class="absolute inset-0 bg-terminal-green/0 group-hover:bg-terminal-green/10 transition-colors duration-300 pointer-events-none z-10"></div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<!-- Lightbox Container -->
<div id="lightbox" class="fixed inset-0 z-50 hidden opacity-0 transition-opacity duration-300 bg-terminal-dark/95 backdrop-blur-xl flex items-center justify-center" aria-modal="true" role="dialog" aria-label="Image gallery">
  <button id="lightbox-close" class="absolute top-6 right-6 z-50 text-terminal-dim hover:text-terminal-green transition-all duration-300 p-3 bg-terminal-surface/50 border border-terminal-border hover:border-terminal-green rounded-full focus:outline-none focus:ring-2 focus:ring-terminal-green hover:shadow-[0_0_15px_rgba(74,222,128,0.2)] active:scale-95" aria-label="Close lightbox">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  
  <button id="lightbox-prev" class="absolute left-6 z-50 text-terminal-dim hover:text-terminal-green transition-all duration-300 p-4 bg-terminal-surface/30 border border-terminal-border/50 hover:bg-terminal-surface hover:border-terminal-green rounded-full focus:outline-none focus:ring-2 focus:ring-terminal-green hover:shadow-[0_0_15px_rgba(74,222,128,0.2)] active:scale-95" aria-label="Previous image">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  
  <div class="lightbox-content relative max-w-[90vw] max-h-[90vh] flex flex-col items-center justify-center">
    <div class="relative group">
      <img id="lightbox-image" src="" alt="" class="max-w-full max-h-[80vh] object-contain shadow-[0_0_50px_rgba(0,0,0,0.5)] rounded-lg border border-terminal-border/50" />
      <div class="absolute inset-0 rounded-lg shadow-[inset_0_0_0_1px_rgba(255,255,255,0.1)] pointer-events-none"></div>
    </div>
    <div id="lightbox-caption" class="mt-6 font-mono text-terminal-light-surface bg-terminal-surface/80 px-6 py-2 rounded-full border border-terminal-border text-sm md:text-base hidden text-center shadow-lg"></div>
  </div>
  
  <button id="lightbox-next" class="absolute right-6 z-50 text-terminal-dim hover:text-terminal-green transition-all duration-300 p-4 bg-terminal-surface/30 border border-terminal-border/50 hover:bg-terminal-surface hover:border-terminal-green rounded-full focus:outline-none focus:ring-2 focus:ring-terminal-green hover:shadow-[0_0_15px_rgba(74,222,128,0.2)] active:scale-95" aria-label="Next image">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>