---
layout: base.njk
title: Tags
permalink: /tags/
---

<!-- Hero -->
<section class="text-center py-12 mb-8">
  <h1 class="text-4xl md:text-5xl font-bold mb-4 text-terminal-green font-mono">
    All Tags
  </h1>
  <p class="text-lg text-terminal-dim dark:text-terminal-dim max-w-xl mx-auto">
    Browse posts by topic. {{ collections.validTagList.length }} topics to explore.
  </p>
</section>

{% set tagList = collections.validTagList %}

{% if tagList.length === 0 %}
  <div class="text-center py-16 bg-terminal-surface dark:bg-terminal-surface rounded-2xl border border-terminal-border dark:border-terminal-border">
    <p class="text-terminal-dim dark:text-terminal-dim">No tags found yet!</p>
  </div>
{% else %}
  <div class="flex flex-wrap justify-center gap-4">
    {% for tag in tagList %}
      {% set postCount = collections.posts | getByTag(tag) | length %}
      <a href="/tags/{{ tag | slugify }}/" class="group relative">
        <div class="px-6 py-4 bg-terminal-surface dark:bg-terminal-surface rounded-xl border border-terminal-border dark:border-terminal-border hover:border-terminal-green dark:hover:border-terminal-green hover:shadow-lg hover:shadow-terminal-green/10 transition-all duration-300 hover:-translate-y-1">
          <div class="flex items-center gap-3">
            <span class="text-2xl font-bold text-terminal-green group-hover:text-terminal-cyan transition-colors">#{{ tag }}</span>
            <span class="text-sm text-terminal-dim dark:text-terminal-dim bg-terminal-dark dark:bg-terminal-dark px-2 py-1 rounded-full">{{ postCount }}</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
{% endif %}

<!-- Back to Posts -->
<div class="mt-16 text-center">
  <a href="/" class="btn btn-primary">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    Back to All Posts
  </a>
</div>
