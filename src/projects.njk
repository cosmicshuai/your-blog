---
layout: base.njk
title: Projects
---

<!-- Terminal Header Section -->
<section class="mb-20">
  <div class="terminal-window bg-terminal-surface/80 backdrop-blur-md border border-terminal-border rounded-xl overflow-hidden max-w-3xl mx-auto shadow-2xl relative group">
    <div class="absolute inset-0 bg-gradient-to-br from-terminal-green/5 to-terminal-cyan/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    <div class="terminal-chrome bg-terminal-darker/90 px-4 py-3 flex items-center justify-between border-b border-terminal-border">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500/80 hover:bg-red-400 transition-colors"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/80 hover:bg-yellow-400 transition-colors"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/80 hover:bg-green-400 transition-colors"></div>
      </div>
      <div class="text-xs text-terminal-dim font-mono flex items-center gap-2">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
        ~/workspace/projects
      </div>
    </div>
    <div class="terminal-body p-6 md:p-10 font-mono text-left relative z-10">
      <div class="flex items-center gap-2 text-lg md:text-xl text-terminal-light-surface">
        <span class="text-terminal-green select-none">$</span>
        <span class="text-terminal-light-surface typing-animation">ls -la --color=auto</span>
      </div>
      <p class="mt-6 text-terminal-dim text-sm md:text-base leading-relaxed border-l-2 border-terminal-green/30 pl-4 py-1">
        Showcasing projects that explore ideas at the intersection of systems, performance, and human-computer interaction. Total packages: <span class="text-terminal-cyan">{{ projects.length }}</span>.
      </p>
    </div>
  </div>
</section>

<!-- Projects Grid Section -->
<section class="max-w-4xl mx-auto pb-12">
  {% if projects.length === 0 %}
    <!-- Empty State -->
    <div class="text-center py-24 bg-terminal-surface/30 backdrop-blur-sm rounded-2xl border border-dashed border-terminal-border relative overflow-hidden group">
      <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(74,222,128,0.02)_50%,transparent_75%)] bg-[length:250%_250%,100%_100%] animate-[gradient_3s_linear_infinite] opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <div class="relative z-10">
        <div class="font-mono mb-4 text-xl">
          <span class="text-terminal-green">$</span>
          <span class="text-terminal-dim">ls</span>
        </div>
        <p class="text-terminal-light-surface mb-3 font-mono font-medium">No projects found</p>
        <code class="bg-terminal-darker/80 px-4 py-2 rounded-lg text-sm text-terminal-green inline-block border border-terminal-border/50 shadow-inner shadow-black/20">src/_data/projects.json</code>
      </div>
    </div>
  {% else %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {% for project in projects %}
        <a 
          href="{{ project.url }}" 
          target="_blank" 
          rel="noopener noreferrer"
          aria-label="View {{ project.name }}"
          class="relative block group"
          data-reveal
          style="transition-delay: {{ loop.index0 * 50 }}ms;"
        >
          <!-- Animated gradient border background -->
          <div class="absolute -inset-0.5 bg-gradient-to-r from-terminal-green to-terminal-cyan rounded-2xl blur opacity-0 group-hover:opacity-30 transition duration-500"></div>
          
          <div class="relative h-full bg-terminal-surface/80 backdrop-blur-md border border-terminal-border rounded-xl flex flex-col group-hover:border-terminal-green/50 transition-all duration-300 transform group-hover:-translate-y-1 overflow-hidden shadow-lg shadow-black/10">
            <!-- Mini terminal header -->
            <div class="px-4 py-2 border-b border-terminal-border/50 bg-terminal-darker/40 flex justify-between items-center">
              <div class="flex items-center gap-1.5 opacity-50 group-hover:opacity-100 transition-opacity">
                <div class="w-2 h-2 rounded-full bg-terminal-border group-hover:bg-red-500/80 transition-colors"></div>
                <div class="w-2 h-2 rounded-full bg-terminal-border group-hover:bg-yellow-500/80 transition-colors"></div>
                <div class="w-2 h-2 rounded-full bg-terminal-border group-hover:bg-green-500/80 transition-colors"></div>
              </div>
              <div class="text-[10px] text-terminal-dim font-mono uppercase tracking-wider">{{ project.name | replace(' ', '-') }}.exe</div>
            </div>

            <div class="p-6 flex flex-col flex-grow">
              <!-- Project Header -->
              <div class="flex items-start justify-between gap-4 mb-4">
                <h3 class="text-xl font-bold text-terminal-light-surface group-hover:text-terminal-green transition-colors font-mono tracking-tight flex items-center gap-2">
                  <span class="text-terminal-green opacity-0 group-hover:opacity-100 -ml-4 w-4 transition-all duration-300">❯</span>
                  {{ project.name }}
                </h3>
                
                <!-- Status Indicator -->
                <div class="flex-shrink-0 flex items-center gap-2 pt-1">
                  {% if project.status === "active" %}
                    <span class="relative flex h-2.5 w-2.5" aria-label="Active project">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-terminal-green opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-terminal-green"></span>
                    </span>
                  {% elif project.status === "wip" %}
                    <span class="relative flex h-2.5 w-2.5" aria-label="Work in progress">
                      <span class="animate-pulse absolute inline-flex h-full w-full rounded-full bg-yellow-500 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-yellow-500/80"></span>
                    </span>
                  {% else %}
                    <span class="w-2.5 h-2.5 rounded-full bg-terminal-dim border border-terminal-border" aria-label="Archived project"></span>
                  {% endif %}
                </div>
              </div>

              <!-- Description -->
              <p class="text-terminal-dim text-sm mb-6 flex-grow leading-relaxed">
                {{ project.description }}
              </p>

              <!-- Footer with Tags and Icon -->
              <div class="flex items-end justify-between mt-auto pt-4 border-t border-terminal-border/30">
                <!-- Tags -->
                {% if project.tags %}
                  <div class="flex flex-wrap gap-2 pr-4">
                    {% for tag in project.tags %}
                      <span class="text-xs font-mono px-2.5 py-1 rounded border border-terminal-green/20 text-terminal-green bg-terminal-green/5 group-hover:bg-terminal-green group-hover:text-terminal-darker transition-colors duration-300">
                        {{ tag }}
                      </span>
                    {% endfor %}
                  </div>
                {% endif %}

                <!-- External Link Icon -->
                <div class="w-8 h-8 rounded-full bg-terminal-darker border border-terminal-border flex items-center justify-center group-hover:border-terminal-green group-hover:bg-terminal-green/10 transition-all duration-300 group-hover:translate-x-1 group-hover:-translate-y-1">
                  <svg class="w-4 h-4 text-terminal-dim group-hover:text-terminal-green transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  {% endif %}
</section>