{
  "name": "personal-blog",
  "version": "1.0.0",
  "description": "Personal blog with Eleventy, Tailwind CSS, and Cloudflare Pages",
  "type": "module",
  "scripts": {
    "build": "npm run build:css && eleventy",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./src/styles/output.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./src/styles/output.css --watch",
    "watch:11ty": "eleventy --serve --watch",
    "dev": "npm run build:css && concurrently \"npm run watch:css\" \"npm run watch:11ty\"",
    "serve": "eleventy --serve",
    "debug": "DEBUG=Eleventy* eleventy"
  },
  "keywords": [
    "blog",
    "eleventy",
    "11ty",
    "tailwindcss"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@tailwindcss/typography": "^0.5.20",
    "concurrently": "^9.2.4",
    "markdown-it-anchor": "^9.2.1",
    "markdown-it-table-of-contents": "^1.2.0",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.19"
  },
  "overrides": {
    "sharp": "^0.35.3"
  }
}
